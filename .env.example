# valantic Knowledge Layer — local environment
# Copy this file to ".env" and fill in your own values. NEVER commit the real .env.
#
#   cp .env.example .env
#
# Get a personal key from https://console.anthropic.com/  → API Keys.
# Do NOT paste a shared/production key or any real secret in here.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the MCP server / scripts (override if you like)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Local storage ---
# Folder holding the markdown+frontmatter memory files (the vendor-neutral store)
MEMORY_DIR=./memory

# --- Dashboard REST API (serve_api.py) ---
API_HOST=127.0.0.1
API_PORT=8787
